{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danieltsai0423/Production-AI-SDD-Skill-Pack/schemas/change.schema.json",
  "title": "Change proposal frontmatter",
  "description": "Frontmatter contract for a spec delta / change-proposal.md.",
  "type": "object",
  "required": ["id", "title", "target_spec", "status", "risk_level"],
  "additionalProperties": true,
  "properties": {
    "id": {"type": "string", "pattern": "^CHG-[0-9]{3,}$"},
    "title": {"type": "string", "minLength": 3},
    "target_spec": {"type": "string", "pattern": "^FEAT-[0-9]{3,}$"},
    "status": {"type": "string", "enum": ["proposed", "approved", "implemented", "archived"]},
    "risk_level": {"type": "integer", "minimum": 0, "maximum": 3},
    "created_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "updated_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"}
  }
}
