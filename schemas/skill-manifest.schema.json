{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danieltsai0423/Production-AI-SDD-Skill-Pack/schemas/skill-manifest.schema.json",
  "title": "Agent Skill manifest (SKILL.md frontmatter)",
  "description": "Frontmatter contract for a canonical pai-* skill. Directory name must equal name.",
  "type": "object",
  "required": ["name", "description"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^pai-[a-z0-9]+(-[a-z0-9]+)*$",
      "maxLength": 64,
      "description": "Lowercase-hyphenated, pai- prefixed; must equal the skill directory name."
    },
    "description": {
      "type": "string",
      "minLength": 40,
      "maxLength": 1024,
      "description": "States what the skill does, when to trigger, and when NOT to trigger."
    },
    "license": {"type": "string"},
    "compatibility": {"type": "string"},
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "pack": {"type": "string"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+"},
        "category": {
          "type": "string",
          "enum": ["sdd-core", "production-review"]
        }
      }
    }
  }
}
